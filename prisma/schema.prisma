generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  AUTHOR
  ADMIN
  SUPER_ADMIN
}

enum AuthorStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum BookType {
  PUBLISHED
  UNPUBLISHED
}

enum BookLanguage {
  ENGLISH
  ARABIC
  HAUSA
  FULFULDE
}

enum BookFormat {
  BOOK
  AUDIO
  VIDEO
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  books         Book[]
  events        Event[]
  authorProfile AuthorProfile?
}

model AuthorProfile {
  id         String       @id @default(uuid())
  penName    String
  bio        String?
  avatarUrl  String?
  status     AuthorStatus @default(PENDING)
  reviewNote String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  books Book[]

  @@index([status])
}

model Scholar {
  id         String   @id @default(uuid())
  name       String
  biography  String?
  pictureUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  books Book[]
}

model Book {
  id          String       @id @default(uuid())
  title       String
  description String?
  coverUrl    String?
  type        BookType     @default(UNPUBLISHED)
  status      BookStatus   @default(DRAFT)
  language    BookLanguage @default(ARABIC)
  format      BookFormat   @default(BOOK)
  readCount   Int          @default(0)
  reviewNote  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  scholarId String
  scholar   Scholar @relation(fields: [scholarId], references: [id])

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  authorProfileId String?
  authorProfile   AuthorProfile? @relation(fields: [authorProfileId], references: [id])

  volumes BookVolume[]

  @@index([status])
  @@index([scholarId])
  @@index([authorProfileId])
}

model BookVolume {
  id        String   @id @default(uuid())
  title     String
  fileUrl   String
  fileType  String
  order     Int      @default(1)
  createdAt DateTime @default(now())

  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  createdAt   DateTime @default(now())

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])
}

model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?
  createdAt DateTime @default(now())
}
